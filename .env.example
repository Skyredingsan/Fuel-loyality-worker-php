APP_NAME="Топливный Альянс"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Moscow
APP_URL=http://localhost:8080
APP_LOCALE=ru
APP_FALLBACK_LOCALE=ru
APP_FAKER_LOCALE=ru_RU

# PostgreSQL 17
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=fuel_points
DB_USERNAME=fuel
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Queue & Cache & Session
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=file

# JWT (tymon/jwt-auth)
JWT_SECRET=
JWT_TTL=1440
JWT_REFRESH_TTL=20160

# Broadcasting (Reverb)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_PUBLIC_HOST=localhost
REVERB_PUBLIC_PORT=8081
REVERB_PUBLIC_SCHEME=http

# File uploads
FILESYSTEM_DISK=local
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx,xls,xlsx

# Mail
MAIL_MAILER=log

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug