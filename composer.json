{
  "name": "fuel-alliance/fuel-points",
  "type": "project",
  "description": "Топливный Альянс — программа лояльности ТМ АЗС (Laravel 13 + PHP 8.5 + PostgreSQL 17 + DDD)",
  "license": "Apache-2.0",
  "require": {
    "php": "^8.5",
    "laravel/framework": "^13.0",
    "laravel/reverb": "^1.0",
    "league/csv": "^9.0",
    "predis/predis": "^2.0",
    "tymon/jwt-auth": "^2.1"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "laravel/pint": "^1.18",
    "laravel/tinker": "^3.0",
    "mockery/mockery": "^1.6",
    "pestphp/pest": "^4.7",
    "pestphp/pest-plugin-faker": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "FuelPoints\\": "src/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
